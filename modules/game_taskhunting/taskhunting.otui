      ScrollablePanel
        id: shopItemsPanel
        anchors.fill: parent
        padding: 10
        vertical-scrollbar: shopScrollBar
        layout:
          type: grid
          cell-size: 296 146
          cell-spacing: 10
          num-columns: 3
