PreferredListItem < UIWidget
  height: 36
  @onClick: modules.game_taskhunting.selectPreferredItem(self)

  UIWidget
    id: creatureSlot
    size: 36 36
    anchors.verticalCenter: parent.verticalCenter
    anchors.left: parent.left
    margin-left: 4
    phantom: true

  UILabel
    id: creatureName
    anchors.verticalCenter: parent.verticalCenter
    anchors.left: creatureSlot.right
    margin-left: 6
    text-auto-resize: true
    color: #dfdfdf
    font: $var-cip-font
    phantom: true

// ────────────────────────────────────────────────────────────────────────────
// SOUL SEALS (Soulpit / Animus Mastery) — ported from Atualizacao 1524 HTML.
// Triggered when the player uses the Soulpit Obelisk (item id 47367/47379).
// The server replies with opcode 0xBA which OTCV8's parseTaskHuntingBasicData
// decodes into g_game.onSoulsealsData(entries) — handled by taskhunting_soulseal.lua.
// ────────────────────────────────────────────────────────────────────────────

SoulSealRowItem < UIWidget
  height: 36
  background-color: alpha
  $on:
    background-color: #585858
  $hover !on:
    background-color: #414141

  // Mirrors PreferredListItem.creatureSlot — same 36×36 box, populated from
  // Lua via g_ui.createWidget('UICreature', ...) + setCreatureSize(36).
  UIWidget
    id: creatureSlot
    size: 36 36
    anchors.verticalCenter: parent.verticalCenter
    anchors.left: parent.left
    margin-left: 4
    phantom: true

  UILabel
    id: nameLabel
    anchors.verticalCenter: parent.verticalCenter
    anchors.left: creatureSlot.right
    margin-left: 6
    text-auto-resize: true
    color: #dfdfdf
    font: $var-cip-font
    phantom: true

  // Cost stack at the right side: icon → label → done-icon, in declaration
  // order so anchors resolve backwards (no forward references).
  UIWidget
    id: costIcon
    size: 16 16
    anchors.verticalCenter: parent.verticalCenter
    anchors.right: parent.right
    margin-right: 8
    image-source: /images/task_board/icon-currency-soulseals
    phantom: true

  Label
    id: costLabel
    anchors.verticalCenter: parent.verticalCenter
    anchors.right: costIcon.left
    margin-right: 4
    text-align: right
    font: $var-cip-font
    color: #dfdfdf
    text-auto-resize: true
    phantom: true

  UIWidget
    id: doneIcon
    size: 14 14
    anchors.verticalCenter: parent.verticalCenter
    anchors.right: costLabel.left
    margin-right: 6
    image-source: /images/store/icon-yes
    phantom: true
    visible: false

SoulSealsWindow < NewMainWindow
  id: soulSealsWindow
  !text: tr('Soulseals')
  size: 400 520
  anchors.centerIn: parent
  @onEscape: modules.game_taskhunting.hideSoulSeals()

  // ── Footer (defined first so other widgets can anchor.bottom to it without
  // forward references that OTML mis-resolves as "recursively anchored").
  Button
    id: closeBtn
    width: 70
    height: 22
    anchors.bottom: parent.bottom
    anchors.right: parent.right
    margin-bottom: 14
    margin-right: 14
    !text: tr('Close')
    @onClick: modules.game_taskhunting.hideSoulSeals()

  Panel
    id: balancePanel
    width: 100
    height: 22
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    margin-bottom: 14
    margin-left: 14
    image-source: /images/ui/infoPanel
    image-border: 3
    UIWidget
      id: balanceIcon
      size: 14 14
      anchors.verticalCenter: parent.verticalCenter
      anchors.left: parent.left
      margin-left: 6
      image-source: /images/task_board/icon-currency-soulseals
      phantom: true
    Label
      id: balanceLabel
      anchors.verticalCenter: parent.verticalCenter
      anchors.left: prev.right
      margin-left: 6
      text-auto-resize: true
      font: $var-cip-font
      color: $var-text-cip-color
      !text: '0'

  HorizontalSeparator
    id: footerSep
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: closeBtn.top
    margin-left: 10
    margin-right: 10
    margin-bottom: 8

  // ── Bottom selected-creature area
  // Height 80 = 6 (top pad) + name(14) + 2 + category(14) + 4 + fightRow(22) + 6 (bottom pad).
  Panel
    id: selectedPanel
    height: 80
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: footerSep.top
    margin-left: 14
    margin-right: 14
    margin-bottom: 8
    image-source: /images/ui/1pixel-down-frame
    image-border: 3
    padding: 4

    UIWidget
      id: previewFrame
      size: 64 64
      anchors.verticalCenter: parent.verticalCenter
      anchors.left: parent.left
      margin-left: 4
      image-source: /images/ui/item
      phantom: true

      UICreature
        id: selectedPreview
        size: 56 56
        anchors.centerIn: parent
        idle-animate: true
        visible: false
        phantom: true

    Label
      id: selectedName
      anchors.top: parent.top
      anchors.left: previewFrame.right
      margin-top: 6
      margin-left: 10
      font: $var-cip-font
      color: $var-text-cip-color
      text-auto-resize: true
      !text: tr('No creature selected')

    Label
      id: selectedCategory
      anchors.top: selectedName.bottom
      anchors.left: previewFrame.right
      margin-top: 2
      margin-left: 10
      font: $var-cip-font
      color: #C28400
      text-auto-resize: true

    // Fight row (Fight button + cost panel + help icon) anchored to the
    // bottom — stacked BELOW the name/category labels so they don't overlap.
    Button
      id: fightBtn
      width: 60
      height: 22
      anchors.bottom: parent.bottom
      anchors.left: previewFrame.right
      margin-bottom: 4
      margin-left: 10
      !text: tr('Fight')
      enabled: false
      @onClick: modules.game_taskhunting.confirmSoulSealFight()

    // Cost display: uses the same /images/ui/infoPanel asset the rest of the
    // task board uses for value chips so the Soulpit panel matches the look.
    Panel
      id: selectedCostPanel
      width: 56
      height: 20
      anchors.verticalCenter: fightBtn.verticalCenter
      anchors.left: fightBtn.right
      margin-left: 10
      image-source: /images/ui/infoPanel
      image-border: 3

      UIWidget
        id: selectedCostIcon
        size: 14 14
        anchors.verticalCenter: parent.verticalCenter
        anchors.right: parent.right
        margin-right: 4
        image-source: /images/task_board/icon-currency-soulseals
        phantom: true

      Label
        id: selectedCostLabel
        anchors.verticalCenter: parent.verticalCenter
        anchors.right: selectedCostIcon.left
        margin-right: 4
        font: $var-cip-font
        color: $var-text-cip-color
        text-auto-resize: true
        !text: '0'

    UIWidget
      id: selectedHintIcon
      size: 16 16
      anchors.verticalCenter: fightBtn.verticalCenter
      anchors.left: selectedCostPanel.right
      margin-left: 8
      image-source: /images/skin/show-gui-help-grey
      tooltip-delayed: true
      !tooltip: tr('Select a creature from the list.')

  // ── Top filter row: search input + clear button + category combobox.
  // Define right-side widgets first so left-side widgets can anchor to them.
  ComboBox
    id: categoryCombo
    width: 90
    height: 22
    anchors.top: parent.top
    anchors.right: parent.right
    margin-top: 12
    margin-right: 14
    @onSetup: |
      self:addOption('All',         '1')
      self:addOption('Harmless',    '2')
      self:addOption('Trivial',     '3')
      self:addOption('Easy',        '4')
      self:addOption('Medium',      '5')
      self:addOption('Hard',        '6')
      self:addOption('Challenging', '7')
    @onOptionChange: modules.game_taskhunting.changeSoulSealCategory(self:getCurrentOption().data)

  Button
    id: searchClearBtn
    !text: 'X'
    width: 22
    height: 22
    anchors.top: categoryCombo.top
    anchors.right: categoryCombo.left
    margin-right: 4
    @onClick: |
      local edit = self:getParent():recursiveGetChildById('searchInput')
      if edit then edit:setText('') end

  TextEdit
    id: searchInput
    height: 22
    anchors.top: categoryCombo.top
    anchors.left: parent.left
    anchors.right: searchClearBtn.left
    margin-left: 14
    margin-right: 4
    !placeholder: tr('Type to search')
    @onTextChange: modules.game_taskhunting.filterSoulSeals(self:getText())

  // List header (2 columns: Creatures | Soulseals)
  Panel
    id: listHeader
    height: 18
    anchors.top: searchInput.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    margin-top: 10
    margin-left: 14
    margin-right: 14
    background-color: alpha
    Label
      !text: tr('Creatures')
      anchors.verticalCenter: parent.verticalCenter
      anchors.left: parent.left
      margin-left: 70
      font: $var-cip-font
      color: #aaaaaa
    Label
      !text: tr('Soulseals')
      anchors.verticalCenter: parent.verticalCenter
      anchors.right: parent.right
      margin-right: 32
      font: $var-cip-font
      color: #aaaaaa

  // ── List + scrollbar. Scrollbar defined before the panel so it can be
  // referenced by anchors.right without a forward-resolution.
  VerticalScrollBar
    id: soulSealListScrollBar
    width: 12
    anchors.top: listHeader.bottom
    anchors.bottom: selectedPanel.top
    anchors.right: parent.right
    margin-top: 2
    margin-right: 14
    margin-bottom: 10
    step: 38
    pixels-scroll: true

  ScrollablePanel
    id: soulSealList
    anchors.top: listHeader.bottom
    anchors.left: listHeader.left
    anchors.right: soulSealListScrollBar.left
    anchors.bottom: selectedPanel.top
    margin-top: 2
    margin-bottom: 10
    margin-right: 2
    vertical-scrollbar: soulSealListScrollBar
    image-source: /images/ui/1pixel-down-frame
    image-border: 3
    padding: 2
    layout:
      type: verticalBox
      align-top: true
