WeeklyKillTask < Panel
  size: 144 100
  image-source: /images/ui/t2pixel-up-frame-borderimage
  image-border: 6
  image-border-top: 27
  focusable: false

  Label
    id: monsterName
    width: 130
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: 2
    font: $var-cip-font
    color: $var-text-color-disabled
    text-auto-resize: false
    text-align: center

  UIWidget
    id: creatureIcon
    size: 66 66
    image-source: /images/ui/item66
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 26
    margin-left: 8

  UIWidget
    id: anyCreatureImg
    size: 64 64
    image-source: /images/task_bounty/any_creature
    anchors.centerIn: creatureIcon
    visible: false

  Label
    id: killCurrent
    anchors.bottom: killOf.top
    anchors.left: creatureIcon.right
    margin-left: 21
    font: $var-cip-font
    color: #d13b3b
    text-auto-resize: true
    text-align: bottom-center

  Label
    id: killOf
    !text: tr('of')
    anchors.verticalCenter: creatureIcon.verticalCenter
    anchors.left: creatureIcon.right
    margin-left: 21
    font: verdana-11px-monochrome
    color: #dfdfdf
    text-auto-resize: true
    text-align: center

  Label
    id: killTotal
    anchors.top: killOf.bottom
    anchors.left: creatureIcon.right
    margin-left: 21
    font: $var-cip-font
    color: #dfdfdf
    text-auto-resize: true
    text-align: top-center

  UIWidget
    id: doneIcon
    size: 11 11
    image-source: /images/store/icon-yes
    anchors.verticalCenter: creatureIcon.verticalCenter
    anchors.left: creatureIcon.right
    margin-left: 21
    visible: false

WeeklyDeliveryTask < Panel
  size: 144 100
  image-source: /images/ui/t2pixel-up-frame-borderimage
  image-border: 6
  image-border-top: 27
  focusable: false

  Label
    id: monsterName
    width: 130
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: 2
    font: $var-cip-font
    color: $var-text-color-disabled
    text-auto-resize: false
    text-align: center

  UIWidget
    id: itemIcon
    size: 66 66
    image-source: /images/ui/item66
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 26
    margin-left: 8

    UIItem
      id: itemDisplay
      size: 34 34
      anchors.centerIn: parent
      virtual: true
      image-source:
      @onSetup: self._skipRarityFrame = true

  Label
    id: killCurrent
    anchors.top: itemIcon.top
    anchors.left: itemIcon.right
    margin-left: 27
    font: $var-cip-font
    color: #d13b3b
    text-auto-resize: true
    text-align: top-center

  Label
    id: killOf
    !text: tr('of')
    anchors.top: killCurrent.bottom
    anchors.left: itemIcon.right
    margin-left: 27
    font: verdana-11px-monochrome
    color: #dfdfdf
    text-auto-resize: true
    text-align: center

  Label
    id: killTotal
    anchors.top: killOf.bottom
    anchors.left: itemIcon.right
    margin-left: 27
    font: $var-cip-font
    color: #dfdfdf
    text-auto-resize: true
    text-align: top-center

  UIWidget
    id: doneIcon
    size: 11 11
    image-source: /images/store/icon-yes
    anchors.verticalCenter: itemIcon.verticalCenter
    anchors.left: itemIcon.right
    margin-left: 27
    visible: false

  Button
    id: deliverBtn
    !text: tr('Deliver')
    size: 43 20
    anchors.bottom: itemIcon.bottom
    anchors.left: itemIcon.right
    margin-left: 17

BonusPromotionItem < Panel
  size: 296 146
  image-source: /images/ui/p2pixel-up-frame-borderimage
  image-clip: 0 0 100 238
  image-border: 2
  font: $var-cip-font
  text-offset: 0 1
  text-align: top

  UIWidget
    id: itemIcon
    size: 66 66
    image-source: /images/ui/item66
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 27
    margin-left: 10

    UIWidget
      id: promoIcon
      image-source: /images/task_bounty/icon_tasksystem_promotionpoint
      anchors.centerIn: parent
      size: 66 66

  Label
    id: promoTitle
    !text: tr('Bonus Promotion')
    font: $var-cip-font
    color: $var-text-cip-color
    anchors.top: parent.top
    anchors.left: promoIcon.right
    anchors.right: parent.right
    margin-top: 30
    margin-left: 10
    margin-right: 10
    text-auto-resize: false
    text-align: top-left

  Label
    id: promoDesc
    !text: tr('+1 Wheel of Destiny point')
    font: verdana-11px-monochrome
    color: #dfdfdf
    anchors.top: promoTitle.bottom
    anchors.left: promoIcon.right
    anchors.right: parent.right
    margin-top: 5
    margin-left: 10
    margin-right: 10
    text-wrap: true
    text-align: top-left

  HorizontalSeparator
    anchors.bottom: parent.bottom
    anchors.horizontalCenter: parent.horizontalCenter
    margin-bottom: 43
    width: 276
    height: 2

  Button
    id: buyButton
    !text: tr('Buy')
    text-align: center
    anchors.left: parent.left
    anchors.bottom: parent.bottom
    margin-left: 10
    margin-bottom: 7
    width: 64
    height: 20

  Panel
    id: infoPanel
    size: 104 20
    image-source: /images/ui/infoPanel
    image-border: 3
    anchors.left: buyButton.right
    anchors.verticalCenter: buyButton.verticalCenter
    margin-left: 10

    UIWidget
      id: priceIcon
      image-source: /images/task_bounty/task_coin
      anchors.right: parent.right
      anchors.verticalCenter: parent.verticalCenter
      margin-right: 5

    Label
      id: itemPrice
      font: $var-cip-font
      color: $var-text-cip-color
      text-align: center
      anchors.centerIn: parent
      text-auto-resize: true

  UIWidget
    id: categoryIcon
    image-source: /images/task_bounty/bonusPromotion_icon
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    margin-right: -3
    margin-bottom: 2

ShopItem < Panel
  size: 296 146
  image-source: /images/ui/p2pixel-up-frame-borderimage
  image-clip: 0 0 100 238
  image-border: 2
  font: $var-cip-font
  text-offset: 0 1
  text-align: top
  
  UIWidget
    id: itemIcon
    size: 66 66
    image-source: /images/ui/item66
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 27
    margin-left: 10

  Item
    id: itemReal
    anchors.centerIn: itemIcon
    size: 32 32
    virtual: true
    image-source: 
    visible: false

  UICreature
    id: itemCreature
    anchors.centerIn: itemIcon
    size: 64 64
    visible: false

  HorizontalSeparator
    id: separator
    anchors.bottom: parent.bottom
    anchors.horizontalCenter: parent.horizontalCenter
    margin-bottom: 43
    width: 276
    height: 2

  Button
    id: buyButton
    !text: tr('Buy')
    text-align: center
    anchors.left: parent.left
    anchors.bottom: parent.bottom
    margin-left: 10
    margin-bottom: 7
    width: 64
    height: 20

  Label
    id: itemDesc
    anchors.top: itemIcon.top
    anchors.left: itemIcon.right
    anchors.right: parent.right
    anchors.bottom: separator.top
    margin-left: 10
    margin-right: 10
    margin-bottom: 5
    text-wrap: true
    text-align: top-left
    font: verdana-11px-monochrome
    color: #dfdfdf

  Panel
    id: infoPanel
    size: 104 20
    image-source: /images/ui/infoPanel
    image-border: 3
    anchors.left: buyButton.right
    anchors.verticalCenter: buyButton.verticalCenter
    margin-left: 10

    UIWidget
      id: priceIcon
      image-source: /images/task_bounty/task_coin
      anchors.right: parent.right
      anchors.verticalCenter: parent.verticalCenter
      margin-right: 5

    Label
      id: itemPrice
      font: $var-cip-font
      color: $var-text-cip-color
      text-align: center
      anchors.centerIn: parent
      text-auto-resize: true

  UIWidget
    id: addonIcon
    image-source: /images/task_bounty/addon_icon
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    margin-right: -3
    margin-bottom: 2
    visible: false

  UIWidget
    id: trophyIcon
    image-source: /images/task_bounty/trophy_icon
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    margin-right: -3
    margin-bottom: 2
    visible: false

  UIWidget
    id: mountIcon
    image-source: /images/task_bounty/mount_icon
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    margin-right: -3
    margin-bottom: 2
    visible: false

NewMainWindow
  id: taskBoardWindow
  visible: false
  !text: tr('Task Board')
  font: $var-cip-font
  color: $var-text-color-disabled
  size: 1000 632
  @onEscape: modules.game_taskhunting.closeTaskBoard()

  Panel
    id: optionsTabBar
    size: 968 36
    image-source: /images/game/destiny_wheel/menuBg
    image-border: 1
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.right: parent.right
    margin-top: 12
    margin-left: 12
    margin-right: 12

    Button
      id: bountyTasksBtn
      anchors.top: parent.top
      anchors.left: parent.left
      size: 322 34
      margin-left: 1
      margin-top: 1
      image-source: /images/task_bounty/bounty_button
      image-clip: 0 0 322 34
      checkable: true
      checked: false
      $hover !checked:
        image-clip: 0 0 322 34
      $pressed:
        image-clip: 0 34 322 34
      $checked:
        image-clip: 0 34 322 34
      @onClick: selectTab('bounty')

    Button
      id: weeklyTasksBtn
      anchors.top: parent.top
      anchors.left: prev.right
      size: 322 34
      margin-left: 1
      margin-top: 1
      image-source: /images/task_bounty/weekly_button
      image-clip: 0 0 322 34
      checkable: true
      checked: true
      $hover !checked:
        image-clip: 0 0 322 34
      $pressed:
        image-clip: 0 34 322 34
      $checked:
        image-clip: 0 34 322 34
      @onClick: selectTab('weekly')

    Button
      id: shopBtn
      anchors.top: parent.top
      anchors.right: parent.right
      size: 322 34
      margin-right: 1
      margin-top: 1
      image-source: /images/task_bounty/shop_button
      image-clip: 0 0 322 34
      checkable: true
      $hover !checked:
        image-clip: 0 0 322 34
      $pressed:
        image-clip: 0 34 322 34
      $checked:
        image-clip: 0 34 322 34
      @onClick: selectTab('shop') 

  Panel
    id: bountyTab
    visible: false
    width: 968
    height: 504
    anchors.top: optionsTabBar.bottom
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: 5
    image-source: /images/ui/2pixel_up_frame_borderimage
    image-clip: 0 0 100 100
    image-border: 2

    Panel
      id: setupPanel
      !text: tr('Set Up & Reroll Tasks')
      font: $var-cip-font
      color: $var-text-cip-color
      width: 948
      height: 58
      anchors.top: parent.top
      anchors.horizontalCenter: parent.horizontalCenter
      margin-top: 11
      image-source: /images/ui/t2pixel-up-frame-borderimage
      image-clip: 0 0 100 125
      image-border: 10
      text-align: top
      text-offset: 0 1

      VerticalSeparator
        id: leftSeparator
        anchors.left: parent.left
        anchors.verticalCenter: parent.verticalCenter
        margin-left: 57
        margin-top: 8
        width: 2
        height: 20

      UIWidget
        id: setupInfoIcon
        image-source: /images/ui/info
        anchors.verticalCenter: leftSeparator.verticalCenter
        anchors.right: leftSeparator.left
        margin-right: 25
        &tooltip: tr('Select one of three Bounty tasks to complete and earn a reward.\n\nTasks are grouped by difficulty:\n\n  Beginner tasks include easy creatures.\n  Adept tasks include easy and medium creatures.\n  Expert tasks include medium and hard creatures.\n  Master tasks include hard and challenging creatures.\n\nYou can change the difficulty at any time, but it only takes effect when selecting your next task.\n\nUse the Preferred List to customise which tasks can appear when you roll.\n\nTasks can be re-rolled using Reroll Tokens. One token can be claimed for free each day. You can store up to 10 Reroll Tokens at a time.\n\nThere is a chance for Silver and Gold tasks to appear, which grant greater rewards.')

      VerticalSeparator
        id: centerSeparator
        anchors.horizontalCenter: parent.horizontalCenter
        anchors.verticalCenter: parent.verticalCenter
        margin-top: 8
        width: 2
        height: 20



      Label
        id: taskDifficultyLabel
        !text: tr('Task Difficulty:')
        font: $var-cip-font
        color: $var-text-cip-color
        anchors.left: leftSeparator.right
        anchors.verticalCenter: parent.verticalCenter
        margin-left: 26
        margin-top: 8

      ComboBox
        id: difficultyComboBox
        anchors.left: taskDifficultyLabel.right
        anchors.verticalCenter: parent.verticalCenter
        margin-left: 26
        margin-top: 8


      Button
        id: preferredListBtn
        !text: tr('Preferred List')
        color: $var-text-cip-color
        text-align: center
        anchors.left: difficultyComboBox.right
        anchors.verticalCenter: parent.verticalCenter
        margin-left: 15
        margin-top: 8
        width: 108
        height: 20
        @onClick: modules.game_taskhunting.openPreferredList()

      Button
        id: rerollTasksBtn
        !text: tr('Reroll Tasks')
        color: $var-text-cip-color
        text-align: center
        anchors.left: centerSeparator.right
        anchors.verticalCenter: parent.verticalCenter
        margin-left: 25
        margin-top: 8
        width: 108
        height: 20

      Panel
        id: rerollInfoPanel
        anchors.left: rerollTasksBtn.right
        anchors.verticalCenter: parent.verticalCenter
        margin-left: 15
        margin-top: 8
        width: 40
        height: 20
        image-source: /images/ui/progress

        Label
          id: rerollCoinsLabel
          !text: tr('0')
          font: $var-cip-font
          color: $var-text-cip-color
          text-align: center
          anchors.left: parent.left
          anchors.right: rerollIcon.left
          anchors.verticalCenter: parent.verticalCenter
          margin-right: 2

        UIWidget
          id: rerollIcon
          image-source: /images/task_bounty/reroll_icon
          anchors.right: parent.right
          anchors.verticalCenter: parent.verticalCenter
          margin-right: 3

      Button
        id: claimDailyBtn
        !text: tr('Claim Daily')
        color: $var-text-cip-color
        text-align: center
        anchors.left: rerollInfoPanel.right
        anchors.verticalCenter: parent.verticalCenter
        margin-left: 30
        margin-top: 8
        width: 108
        height: 20

    Panel
      id: tasksPanel
      width: 948
      height: 271
      anchors.top: setupPanel.bottom
      anchors.horizontalCenter: parent.horizontalCenter
      margin-top: 15
      image-source: /images/ui/2pixel_up_frame_borderimage_dark_reversed
      image-clip: 0 0 100 100
      image-border: 2
      layout:
        type: horizontalBox
        spacing: 10
      padding-top: 10
      padding-bottom: 10
      padding-left: 20

      Panel
        id: taskSlot1
        width: 296
        height: 251
        image-source: /images/ui/2pixel-up-frame-borderimage
        image-clip: 0 0 100 100
        image-border: 2

        UIWidget
          id: banner
          anchors.top: parent.top
          anchors.horizontalCenter: parent.horizontalCenter
          margin-top: -6
          image-source: /images/task_bounty/task_banner
          phantom: true

        Label
          id: monsterName
          font: $var-cip-font
          color: $var-text-cip-color
          text-align: center
          anchors.top: banner.top
          anchors.left: banner.left
          anchors.right: banner.right
          margin-top: 12
          text-auto-resize: true

        UIWidget
          id: creatureSlot
          anchors.top: parent.top
          anchors.horizontalCenter: parent.horizontalCenter
          margin-top: 41
          size: 66 66
          image-source: /images/ui/item66

        Label
          id: killProgress
          font: $var-cip-font
          color: $var-text-cip-color
          text-align: center
          anchors.top: creatureSlot.bottom
          anchors.horizontalCenter: parent.horizontalCenter
          margin-top: 5
          text-auto-resize: true

        HorizontalSeparator
          id: separator
          anchors.top: killProgress.bottom
          anchors.horizontalCenter: parent.horizontalCenter
          margin-top: 10
          width: 276
          height: 2

        Label
          id: rewardLabel
          !text: tr('Reward:')
          font: $var-cip-font
          color: $var-text-cip-color
          anchors.top: separator.bottom
          anchors.left: separator.left
          margin-top: 15

        Panel
          id: rewardItem1
