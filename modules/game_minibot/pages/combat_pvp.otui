MiniBotCombatPvpitemSpellDropDownEntry < UIWidget
  border-width: 0
  border-color: #999999
  size: 34 34

  QtButton
    id: leftArrow
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    margin-top: 1
    margin-bottom: 1
    margin-left: 2
    width: 1
    icon: /resources/icons_button_change_minibot
    icon-clip: 0 0 5 14
    icon-offset: -3 0
    visible: false

    $pressed:
      image-clip: 0 46 22 23
      text-offset: 1 1
      icon-offset: -2 1

  QtButton
    id: rightArrow
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    anchors.right: parent.right
    margin-top: 1
    margin-bottom: 1
    margin-right: 2
    width: 1
    icon: /resources/icons_button_change_minibot
    icon-clip: 5 0 5 14
    icon-offset: 2 0
    visible: false

    $pressed:
      image-clip: 0 46 22 23
      text-offset: 1 1
      icon-offset: 3 1

  UIWidget
    id: background
    image-source: /images/ui/containerslot
    image-border: 3
    phantom: true
    anchors.verticalCenter: parent.verticalCenter
    anchors.left: leftArrow.right
    anchors.right: rightArrow.left

  UIWidget
    id: spell
    image-source: /images/game/spells/spell_regular_icons
    image-clip: 0 0 32 32
    size: 32 32
    phantom: true
    anchors.verticalCenter: parent.verticalCenter
    anchors.left: leftArrow.right
    anchors.right: rightArrow.left

MiniBotCombatPvpitemIgnoreDropDownEntry < UIWidget
  id: ignoreAdd
  image-source: /images/ui/containerslot
  image-border: 3
  virtual: true
  size: 34 34

  UIWidget
    id: icon
    anchors.centerIn: parent
    image-source: /resources/icon_new_entry_minibot
    size: 32 32
    opacity: 0.75
    phantom: true

MiniBotCombatPvpSpellDropDownEntry < UIWidget
  image-source: /images/ui/containerslot
  image-border: 3
  size: 34 34

  UIWidget
    id: icon
    image-source: /images/game/spells/spell_regular_icons
    image-clip: 0 0 32 32
    anchors.centerIn: parent
    size: 32 32
    phantom: true

  UIWidget
    id: block
    size: 34 34
    image-source: /resources/minibot_spell_block
    phantom: true
    visible: false

UIWidget
  anchors.fill: parent

  UIWidget
    id: panel
    image-source: /images/ui/window_light
    image-border-left: 2
    image-border-right: 2
    image-border-top: 25
    image-border-bottom: 3
    anchors.left: parent.left
    anchors.top: parent.top
    anchors.right: parent.right
    anchors.bottom: parent.bottom

    Label
      !text: 'PvP'
      anchors.top: parent.top
      anchors.horizontalCenter: parent.horizontalCenter
      margin-top: 2
      phantom: true
      color: #909090

    UIWidget
      id: tankMode
      anchors.top: parent.top
      anchors.left: parent.left
      anchors.right: parent.right
      margin-top: 22
      margin-left: 5
      margin-right: 5
      image-source: /resources/button_phantom
      image-clip: 0 46 22 23
      image-border: 3
      padding: 5
      height: 26

      QtCheckBox
        id: check
        anchors.left: parent.left
        anchors.top: parent.top
        text-horizontal-auto-resize: true
        !text: 'Tank mode (SSA and Might Ring)'
        text-offset: 15 -2
        color: #C0C0C0
        @onCheckChange: |
          modules.game_minibot.callMethod('onTankModeChange', self)

      UIWidget
        id: help
        anchors.right: parent.right
        anchors.verticalCenter: check.verticalCenter
        color: #C0C0C0
        margin-right: 5
        image-source: /images/icons/show_gui_help_grey
        size: 12 12
        !tooltip: 'Enabling Tank Mode the Assistant will automatically equip Stone Skin Amulet and Might Ring if possible.'

    UIWidget
      id: antiParalyze
      anchors.top: tankMode.bottom
      anchors.left: parent.left
      anchors.right: parent.right
      margin-top: 5
      margin-left: 5
      margin-right: 5
      image-source: /resources/button_phantom
      image-clip: 0 46 22 23
      image-border: 3
      padding: 5
      height: 86

      QtCheckBox
        id: check
        anchors.left: parent.left
        anchors.top: parent.top
        text-horizontal-auto-resize: true
        !text: 'Auto-remove paralyze'
        text-offset: 15 -2
        color: #C0C0C0
        @onCheckChange: |
          modules.game_minibot.callMethod('onAntiParalyzeChange', self)

      UIWidget
        id: help
        anchors.right: parent.right
        anchors.verticalCenter: check.verticalCenter
        color: #C0C0C0
        margin-right: 5
        image-source: /images/icons/show_gui_help_grey
        size: 12 12
        !tooltip: 'Auto-remove Paralyze will cast one of the selected spells as soon as you are paralyzed. The priority respect the order from Left to Right.'

      UIWidget
        id: listPanel
        anchors.top: check.bottom
        anchors.right: parent.right
        anchors.left: parent.left
        image-source: /resources/button_phantom
        image-clip: 0 46 22 23
        image-border: 3
        padding: 5
        margin-top: 5
        height: 55

        ScrollablePanel
          id: list
          anchors.fill: parent
          vertical-scrollbar: listScrollBar
          padding: 5
          image-source: /images/ui/miniwindow_gray
          image-border: 3
          padding-right: 20
          layout:
            type: horizontalBox

        VerticalScrollBar
          id: listScrollBar
          anchors.top: list.top
          anchors.bottom: list.bottom
          anchors.right: list.right
          margin-top: 2
          margin-right: 2
          margin-bottom: 2
          step: 10
          pixels-scroll: true

        UIWidget
          id: block
          size: 34 34
          anchors.fill: list
          image-source: /resources/minibot_spell_block
          image-border: 3
          opacity: 0.35
          visible: false

  UIWidget
    id: dropDownCatcher
    anchors.fill: parent
    visible: false

  ScrollablePanel
    id: dropDownMenu
    padding-right: 14
    image-source: /resources/border_minibot_dropdown
    image-border: 5
    vertical-scrollbar: dropDownMenuScrollBar
    anchors.left: parent.left
    anchors.top: parent.top
    margin-left: 10
    size: 328 55
    padding: 8
    visible: false
    layout:
      type: grid
      cell-size: 34 34
      cell-spacing: 4
      flow: true

  VerticalScrollBar
    id: dropDownMenuScrollBar
    anchors.top: dropDownMenu.top
    anchors.bottom: dropDownMenu.bottom
    anchors.right: dropDownMenu.right
    margin-top: 2
    margin-right: 2
    margin-bottom: 2
    step: 32
    pixels-scroll: true
    visible: false
