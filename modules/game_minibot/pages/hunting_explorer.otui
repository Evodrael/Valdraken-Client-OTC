UIWidget
  anchors.fill: parent

  UIWidget
    id: panel
    image-source: /images/ui/window_light
    image-border-left: 2
    image-border-right: 2
    image-border-top: 25
    image-border-bottom: 3
    anchors.left: parent.left
    anchors.top: parent.top
    anchors.right: parent.right
    anchors.bottom: parent.bottom

    Label
      id: title
      !text: 'Auto Explorer'
      anchors.top: parent.top
      anchors.horizontalCenter: parent.horizontalCenter
      text-horizontal-auto-resize: true
      margin-top: 2
      phantom: true
      color: #909090

    ButtonBox
      id: enabled
      anchors.top: parent.top
      anchors.right: parent.right
      font: cipsoftFont
      !text: 'Off'
      size: 50 13
      color: white
      text-offset: 1 2
      checked: false
      image-source: /images/store/button_red
      image-clip: 0 0 98 40
      image-border: 2
      margin-top: 3
      margin-right: 2

      $!checked:
        image-clip: 0 0 22 23
        color: #C0C0C0
        text-offset: 1 1
        change-cursor-image: false
        image-source: /images/store/button_red
        image-clip: 0 0 98 40
        !text: 'Disabled'

      $checked:
        image-clip: 0 46 22 23
        color: #C0C0C0
        text-offset: 2 2
        change-cursor-image: false
        image-source: /images/store/button_green
        image-clip: 0 0 98 40
        !text: 'Enabled'

    UIWidget
      id: lureTab
      anchors.top: parent.top
      anchors.left: parent.left
      anchors.right: parent.right
      margin-top: 22
      margin-left: 5
      margin-right: 5
      image-source: /resources/button_phantom
      image-clip: 0 46 22 23
      image-border: 3
      padding: 5
      height: 78

      QtCheckBox
        id: lure
        anchors.left: parent.left
        anchors.top: parent.top
        text-horizontal-auto-resize: true
        !text: 'Lure monsters'
        text-offset: 17 -2
        color: #C0C0C0
        @onCheckChange: |
          modules.game_minibot.callMethod('onLureChange', self)

      UIWidget
        id: lureHelp
        anchors.right: parent.right
        anchors.verticalCenter: lure.verticalCenter
        color: #C0C0C0
        margin-right: 5
        image-source: /images/icons/show_gui_help_grey
        size: 12 12

      UIWidget
        id: untilLabel
        anchors.left: parent.left
        anchors.top: lure.bottom
        margin-top: 10
        margin-left: 17
        text-horizontal-auto-resize: true
        !text: 'Until find monsters:'
        color: #C0C0C0
        phantom: true
        enabled: false
        opacity: 1

        $disabled:
          opacity: 0.5

      UIWidget
        id: untilHelp
        anchors.right: parent.right
        anchors.verticalCenter: untilLabel.verticalCenter
        color: #C0C0C0
        margin-right: 5
        image-source: /images/icons/show_gui_help_grey
        size: 12 12
        !tooltip: 'Auto Haste will automatically detect when your haste buff is gone and cast the selected spell.'

      TextEdit
        id: untilBox
        anchors.right: untilHelp.left
        anchors.verticalCenter: untilLabel.verticalCenter
        margin-right: 10
        !placeholder: '0'
        width: 50
        color: #C0C0C0
        enabled: false
        text-only-number: true
        @onTextChange: |
          modules.game_minibot.callMethod('onTextOptionChange', self)

      UIWidget
        id: resumeLabel
        anchors.left: parent.left
        anchors.top: untilBox.bottom
        margin-top: 8
        margin-left: 17
        text-horizontal-auto-resize: true
        !text: 'Resume walk when monsters:'
        color: #C0C0C0
        phantom: true
        enabled: false
        opacity: 1

        $disabled:
          opacity: 0.5

      UIWidget
        id: resumeHelp
        anchors.right: parent.right
        anchors.verticalCenter: resumeLabel.verticalCenter
        color: #C0C0C0
        margin-right: 5
        image-source: /images/icons/show_gui_help_grey
        size: 12 12
        !tooltip: 'Auto Haste will automatically detect when your haste buff is gone and cast the selected spell.'

      TextEdit
        id: resume
        anchors.right: resumeHelp.left
        anchors.verticalCenter: resumeLabel.verticalCenter
        margin-right: 10
        !placeholder: '0'
        width: 50
        color: #C0C0C0
        enabled: false
        text-only-number: true
        @onTextChange: |
          modules.game_minibot.callMethod('onTextOptionChange', self)

    UIWidget
      id: stopFightTab
      anchors.top: prev.bottom
      anchors.left: parent.left
      anchors.right: parent.right
      margin-top: 5
      margin-left: 5
      margin-right: 5
      image-source: /resources/button_phantom
      image-clip: 0 46 22 23
      image-border: 3
      padding: 5
      height: 78

      QtCheckBox
        id: stop
        anchors.left: parent.left
        anchors.top: parent.top
        text-horizontal-auto-resize: true
        !text: 'Stop to fight monsters'
        text-offset: 17 -2
        color: #C0C0C0
        @onCheckChange: |
          modules.game_minibot.callMethod('onStopChange', self)

      UIWidget
        id: stopHelp
        anchors.right: parent.right
        anchors.verticalCenter: stop.verticalCenter
        color: #C0C0C0
        margin-right: 5
        image-source: /images/icons/show_gui_help_grey
        size: 12 12

      UIWidget
        id: untilLabel
        anchors.left: parent.left
        anchors.top: stop.bottom
        margin-top: 10
        margin-left: 17
        text-horizontal-auto-resize: true
        !text: 'When find monsters:'
        color: #C0C0C0
        phantom: true
        enabled: false
        opacity: 1

        $disabled:
          opacity: 0.5

      UIWidget
        id: untilHelp
        anchors.right: parent.right
        anchors.verticalCenter: untilLabel.verticalCenter
        color: #C0C0C0
        margin-right: 5
        image-source: /images/icons/show_gui_help_grey
        size: 12 12

      TextEdit
        id: untilBox
        anchors.right: untilHelp.left
        anchors.verticalCenter: untilLabel.verticalCenter
        margin-right: 10
        !placeholder: '0'
        width: 50
        color: #C0C0C0
        enabled: false
        text-only-number: true
        @onTextChange: |
          modules.game_minibot.callMethod('onTextOptionChange', self)

      UIWidget
        id: resumeLabel
        anchors.left: parent.left
        anchors.top: untilBox.bottom
        margin-top: 8
        margin-left: 17
        text-horizontal-auto-resize: true
        !text: 'Resume walk when monsters:'
        color: #C0C0C0
        phantom: true
        enabled: false
        opacity: 1

        $disabled:
          opacity: 0.5

      UIWidget
        id: resumeHelp
        anchors.right: parent.right
        anchors.verticalCenter: resumeLabel.verticalCenter
        color: #C0C0C0
        margin-right: 5
        image-source: /images/icons/show_gui_help_grey
        size: 12 12

      TextEdit
        id: resume
        anchors.right: resumeHelp.left
        anchors.verticalCenter: resumeLabel.verticalCenter
        margin-right: 10
        !placeholder: '0'
        width: 50
        color: #C0C0C0
        enabled: false
        text-only-number: true
        @onTextChange: |
          modules.game_minibot.callMethod('onTextOptionChange', self)
