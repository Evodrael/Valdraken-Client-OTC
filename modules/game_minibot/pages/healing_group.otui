MiniBotHealingGroupitemDropDownEntry < UIItem
  image-source: /images/ui/containerslot
  image-border: 3
  virtual: true
  size: 34 34

MiniBotHealingGroupSpellDropDownEntry < UIWidget
  image-source: /images/ui/containerslot
  image-border: 3
  size: 34 34

  UIWidget
    id: icon
    image-source: /images/game/spells/spell_regular_icons
    image-clip: 0 0 32 32
    anchors.centerIn: parent
    size: 32 32
    phantom: true

  UIWidget
    id: block
    size: 34 34
    image-source: /resources/minibot_spell_block
    phantom: true
    visible: false

MiniBotHealingGroupEntry < UIWidget
  height: 46
  margin-right:

  VerticalSeparator
    id: separatorIcon
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    margin-left: 29

  VerticalSeparator
    id: separatorFrame
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    margin-left: 103

  VerticalSeparator
    id: separatorHealth
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    margin-left: 216

  VerticalSeparator
    id: separatorAction
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    margin-left: 310

  UIWidget
    id: mask
    anchors.fill: parent
    border-color: white
    border-width: 1
    opacity: 1
    visible: false
    phantom: true

  UIWidget
    id: iconTooptip
    !tooltip: 'Your entry is invalid, please reconfigure it!'
    anchors.fill: icon

  UICheckBox
    id: icon
    anchors.left: parent.left
    anchors.verticalCenter: parent.verticalCenter
    image-source: /resources/icon_thumbs_minibot
    image-clip: 25 0 25 25
    checked: false
    size: 25 25

    $checked:
      image-clip: 0 0 25 25

  UIWidget
    id: frameBackground
    image-source: /resources/icon_source_frame_minibot
    size: 38 44
    anchors.verticalCenter: parent.verticalCenter
    anchors.left: parent.left
    margin-left: 48

  UIWidget
    id: virtue
    anchors.verticalCenter: parent.verticalCenter
    anchors.right: frameBackground.left
    margin-right: 4
    image-source: /resources/icons_minibot
    image-clip: 416 0 13 13
    size: 13 13
    visible: false
    !tooltip: 'You will auto-cast Virtue of Sustain before triggering this spell.'

  UIWidget
    id: noVocation
    anchors.verticalCenter: parent.verticalCenter
    anchors.left: frameBackground.right
    margin-left: 4
    image-source: /resources/icons_minibot
    image-clip: 117 0 13 13
    size: 13 13
    visible: false
    !tooltip: 'Your vocation cannot use this spell.'

  UIWidget
    id: frameColor
    anchors.centerIn: frameBackground
    background-color: white
    opacity: 0.05
    size: 32 32
    phantom: true

  UIItem
    id: item
    size: 32 32
    virtual: true
    phantom: true
    anchors.centerIn: frameBackground
    visible: false

  UIWidget
    id: spell
    image-source: /images/game/spells/spell_regular_icons
    image-clip: 0 0 32 32
    size: 32 32
    phantom: true
    anchors.centerIn: frameBackground
    visible: false

  UIWidget
    id: target
    anchors.left: separatorFrame.right
    anchors.right: separatorHealth.left
    anchors.verticalCenter: parent.verticalCenter
    margin-left: 5
    color: #C0C0C0
    phantom: true
    text-wrap: true
    text-align: left
    text-vertical-auto-resize: true

  UIWidget
    id: hp
    !text: '-%'
    anchors.verticalCenter: parent.verticalCenter
    anchors.left: separatorHealth.right
    anchors.right: separatorAction.left
    text-align: center
    font: verdana-11px-antialised
    color: #C0C0C0
    phantom: true

  Panel
    id: buttons
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    anchors.right: parent.right
    margin-top: 3
    margin-bottom: 3
    phantom: true
    auto-focus: first
    width: 54
    visible: false
    layout:
      type: grid
      cell-size: 16 16
      cell-spacing: 2
      flow: true

    QtButton
      id: remove
      icon: /resources/icons_actions_minibot
      icon-clip: 27 0 9 9
      size: 16 16
      @onLeftClick: |
        modules.game_minibot.callMethod('onRemoveEntry', self:getParent():getParent())

      $disabled:
        color: #dfdfdf88
        opacity: 0.5

    UIWidget
      size: 16 16
      phantom: true

    QtButton
      id: upper
      icon: /resources/icons_actions_minibot
      icon-clip: 9 0 9 9
      size: 16 16
      @onLeftClick: |
        modules.game_minibot.callMethod('onMoveUpEntry', self:getParent():getParent())

      $disabled:
        color: #dfdfdf88
        opacity: 0.5

    UIWidget
      size: 16 16
      phantom: true

    UIWidget
      size: 16 16
      phantom: true

    QtButton
      id: lower
      icon: /resources/icons_actions_minibot
      icon-clip: 0 0 9 9
      size: 16 16
      @onLeftClick: |
        modules.game_minibot.callMethod('onMoveDownEntry', self:getParent():getParent())

      $disabled:
        color: #dfdfdf88
        opacity: 0.5

MiniBotHealingGroupNewEntry < UIWidget
  background-color: #3c3c3c
  height: 50
  &ignoreBackground: true
  &ignoreClickFromUiScrollAreaArrow: true
  @onLeftClick: |
    modules.game_minibot.callMethod('onNewEntry', self)

  @onHoverChange: |
    self:getChildById('text'):setColor(self:isHovered() and 'white' or '#C0C0C0')
    self:getChildById('icon'):setOpacity(self:isHovered() and 1 or 0.7)

  HorizontalSeparator
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.top: parent.top
    opacity: 0.3
    phantom: true

  HorizontalSeparator
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    opacity: 0.3
    phantom: true

  UIWidget
    id: text
    anchors.verticalCenter: parent.verticalCenter
    anchors.horizontalCenter: parent.horizontalCenter
    text-horizontal-auto-resize: true
    margin-left: 5
    font: verdana-11px-rounded
    !text: 'New Entry'
    color: #C0C0C0
    phantom: true

  UIWidget
    id: icon
    anchors.verticalCenter: prev.verticalCenter
    anchors.right: prev.left
    image-source: /resources/icon_new_entry_minibot
    size: 32 32
    phantom: true

UIWidget
  anchors.fill: parent

  UIWidget
    id: priority
    image-source: /images/ui/window_light
    image-border-left: 2
    image-border-right: 2
    image-border-top: 25
    image-border-bottom: 3
    anchors.left: parent.left
    anchors.top: parent.top
    anchors.right: parent.right
    height: 336

    ButtonBox 
      id: enabled
      anchors.top: parent.top
      anchors.right: parent.right
      font: cipsoftFont
      !text: 'Off'
      size: 50 13
      color: white
      text-offset: 1 2
      checked: false
      image-source: /images/store/button_red
      image-clip: 0 0 98 40
      image-border: 2
      margin-top: 3
      margin-right: 2

      $!checked:
        image-clip: 0 0 22 23
        color: #C0C0C0
        text-offset: 1 1
        change-cursor-image: false
        image-source: /images/store/button_red
        image-clip: 0 0 98 40
        !text: 'Disabled'

      $checked:
        image-clip: 0 46 22 23
        color: #C0C0C0
        text-offset: 2 2
        change-cursor-image: false
        image-source: /images/store/button_green
        image-clip: 0 0 98 40
        !text: 'Enabled'

    Label
      id: priorityLabel
      !text: 'Priority List'
      anchors.top: parent.top
      anchors.horizontalCenter: parent.horizontalCenter
      text-horizontal-auto-resize: true
      margin-top: 2
      phantom: true
      color: #909090

    Label
      id: typeLabel
      color: #C0C0C0
      anchors.left: parent.left
      anchors.top: parent.top
      margin-top: 22
      margin-left: 8
      !text: 'Selected list:'
      text-horizontal-auto-resize: true
      phantom: true

    CircularCheckBox
      id: custom
      !text: 'Custom'
      anchors.verticalCenter: typeLabel.verticalCenter
      anchors.left: typeLabel.right
      margin-left: 10
      margin-top: 1
      checked: true
      text-horizontal-auto-resize: true
      @onCheckChange: |
        modules.game_minibot.callMethod('onListTypeChange', self)

    CircularCheckBox
      id: guild
      !text: 'Guild'
      anchors.verticalCenter: typeLabel.verticalCenter
      anchors.left: custom.right
      margin-left: 15
      margin-top: 1
      checked: true
      text-horizontal-auto-resize: true
      @onCheckChange: |
        modules.game_minibot.callMethod('onListTypeChange', self)

    CircularCheckBox
      id: party
      !text: 'Party'
      anchors.verticalCenter: typeLabel.verticalCenter
      anchors.left: guild.right
      margin-left: 15
      margin-top: 1
      checked: true
      text-horizontal-auto-resize: true
      @onCheckChange: |
        modules.game_minibot.callMethod('onListTypeChange', self)

    UIWidget
      id: listHelp
      color: #C0C0C0
      anchors.right: parent.right
      anchors.verticalCenter: typeLabel.verticalCenter
      margin-top: 1
      margin-right: 8
      image-source: /images/icons/show_gui_help_grey
      size: 12 12
      !tooltip: 'You must select a pre-selected list to configure your group healing priority.'

    ScrollablePanel
      id: list
      anchors.fill: parent
      anchors.top: parent.top
      vertical-scrollbar: listScrollBar
      padding: 2
      margin-top: 45
      padding-top: 18
      padding-right: 14
      image-source: /images/ui/miniwindow_gray
      image-border: 3
      margin-left: 5
      margin-bottom: 5
      margin-right: 5
      layout:
        type: verticalBox

      MiniBotHealingGroupNewEntry

    UIWidget
      id: listHeader
      anchors.left: list.left
      anchors.right: list.right
      anchors.top: list.top
      margin-top: 2
      margin-left: 2
      margin-right: 2
      background-color: #757575
      height: 15

      UIWidget
        anchors.left: parent.left
        anchors.top: parent.top
        anchors.bottom: parent.bottom
        margin-bottom: 1
        width: 30
        background-color: #363636

        Label
          color: #C0C0C0
          anchors.horizontalCenter: parent.horizontalCenter
          anchors.bottom: parent.bottom
          margin-bottom: 1
          margin-right: 1
          phantom: true
          !text: 'On'

      UIWidget
        id: sourceLabel
        anchors.left: prev.right
        anchors.top: parent.top
        anchors.bottom: parent.bottom
        margin-bottom: 1
        width: 75
        background-color: #363636

        VerticalSeparator
          anchors.top: parent.top
          anchors.bottom: parent.bottom
          anchors.left: parent.left

        Label
          id: label
          color: #C0C0C0
          anchors.horizontalCenter: parent.horizontalCenter
          text-horizontal-auto-resize: true
          anchors.bottom: parent.bottom
          margin-bottom: 1
          margin-right: 1
          phantom: true
          !text: 'Source'

      UIWidget
        id: targetLabel
        anchors.left: prev.right
        anchors.top: parent.top
        anchors.bottom: parent.bottom
        margin-bottom: 1
        width: 114
        background-color: #363636

        VerticalSeparator
          anchors.top: parent.top
          anchors.bottom: parent.bottom
          anchors.left: parent.left

        Label
          id: label
          color: #C0C0C0
          anchors.left: parent.left
          anchors.bottom: parent.bottom
          text-horizontal-auto-resize: true
          margin-bottom: 1
          margin-left: 5
          phantom: true
          !text: 'Target'

      UIWidget
        anchors.left: prev.right
        anchors.top: parent.top
        anchors.bottom: parent.bottom
        margin-bottom: 1
        width: 95
        background-color: #363636

        VerticalSeparator
          anchors.top: parent.top
          anchors.bottom: parent.bottom
          anchors.left: parent.left

        Label
          color: #C0C0C0
          anchors.horizontalCenter: parent.horizontalCenter
          anchors.bottom: parent.bottom
          margin-bottom: 1
          margin-right: 1
          phantom: true
          !text: 'HP'

      UIWidget
        id: actionLabel
        anchors.left: prev.right
        anchors.right: parent.right
        anchors.top: parent.top
        anchors.bottom: parent.bottom
        margin-bottom: 1
        margin-left: 2
        background-color: #363636

        Label
          id: label
          color: #C0C0C0
          anchors.left: parent.left
          anchors.bottom: parent.bottom
          text-horizontal-auto-resize: true
          text-align: left
          margin-bottom: 1
          margin-left: 2
          phantom: true
          !text: 'Action'

    VerticalScrollBar
      id: listScrollBar
      anchors.top: list.top
      anchors.bottom: list.bottom
      anchors.right: list.right
      margin-top: 2
      margin-right: 2
      margin-bottom: 2
      step: 10
      pixels-scroll: true

  UIWidget
    id: config
    image-source: /images/ui/window_light
    image-border-left: 2
    image-border-right: 2
    image-border-top: 25
    image-border-bottom: 3
    anchors.left: parent.left
    anchors.top: priority.bottom
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    margin-top: 5

    Label
      id: title
      !text: 'Configure'
      anchors.top: parent.top
      anchors.horizontalCenter: parent.horizontalCenter
      text-horizontal-auto-resize: true
      margin-top: 2
      phantom: true
      color: #909090

    UIWidget
      id: notSelected
      color: #C0C0C0
      !text: 'Select an entry on the list to configure or create a band-new entry on the + button if possible.'
      text-align: center
      anchors.verticalCenter: parent.verticalCenter
      anchors.left: parent.left
      anchors.right: parent.right
      margin-left: 15
      margin-right: 15
      text-wrap: true
      text-vertical-auto-resize: true
      phantom: true
      visible: false

    UIWidget
      id: panel
      anchors.fill: parent
      margin-left: 5
      margin-right: 5
      margin-bottom: 5
      margin-top: 22
      visible: true

      QtButton
        id: save
        anchors.right: parent.right
        anchors.bottom: parent.bottom
        width: 40
        !text: 'Apply'
        font: cipsoftFont
        color: white

      UIWidget
        id: frameColor
        anchors.centerIn: frameBackground
        image-source: /images/game/actionbar/actionbarslot
        size: 34 34
        phantom: true

      UIWidget
        id: frameBackground
        image-source: /resources/icon_source_frame_minibot
        size: 38 44
        anchors.left: parent.left
        anchors.top: parent.top
        margin-left: 5
        margin-top: 5

      UIItem
        id: item
        size: 32 32
        virtual: true
        phantom: true
        anchors.centerIn: frameBackground
        visible: false

      UIWidget
        id: spell
        image-source: /images/game/spells/spell_regular_icons
        image-clip: 0 0 32 32
        size: 32 32
        phantom: true
        anchors.centerIn: frameBackground
        visible: false

      TextEdit
        id: name
        anchors.left: frameBackground.right
        anchors.bottom: frameBackground.bottom
        margin-bottom: 5
        !placeholder: 'Type to search or drop on slot'
        placeholder-font: cipsoftFont
        color: #C0C0C0
        width: 160
        margin-left: 5

      UIWidget
        id: options
        anchors.left: parent.left
        anchors.bottom: parent.bottom
        image-source: /resources/button_phantom
        image-clip: 0 46 22 23
        image-border: 3
        padding: 5
        size: 195 25

        QtCheckBox
          id: spellCheck
          anchors.left: parent.left
          anchors.bottom: parent.bottom
          text-horizontal-auto-resize: true
          !text: 'Spell entry'
          text-offset: 15 0
          color: #C0C0C0

        QtCheckBox
          id: itemCheck
          anchors.left: spellCheck.right
          anchors.bottom: parent.bottom
          margin-left: 10
          text-horizontal-auto-resize: true
          text-offset: 15 0
          !text: 'Item entry'
          color: #C0C0C0

      UIWidget
        id: hpHelp
        color: #C0C0C0
        anchors.right: parent.right
        anchors.verticalCenter: name.verticalCenter
        margin-right: 2
        image-source: /images/icons/show_gui_help_grey
        size: 12 12
        !tooltip: 'If your Health percent is LOWER than this value, the action can be triggered.'

      TextEdit
        id: hp
        anchors.verticalCenter: prev.verticalCenter
        anchors.right: prev.left
        margin-right: 5
        width: 35
        text-only-number: true
        !placeholder: '0%'
        color: #C0C0C0
        @onTextChange: |
          modules.game_minibot.callMethod('validateTextPercentage', self)

      UIWidget
        !text: 'HP:'
        color: #C0C0C0
        anchors.right: hp.left
        anchors.verticalCenter: hp.verticalCenter
        margin-right: 5

      UIWidget
        id: targetHelp
        color: #C0C0C0
        anchors.left: target.right
        anchors.top: hp.bottom
        margin-left: 5
        margin-top: 10
        image-source: /images/icons/show_gui_help_grey
        size: 12 12
        !tooltip: 'Type the target name to be healed.'

      TextEdit
        id: target
        anchors.top: hp.bottom
        anchors.left: parent.left
        anchors.right: name.right
        margin-left: 65
        margin-top: 5
        !placeholder: 'Type target name'
        placeholder-font: cipsoftFont
        color: #C0C0C0

      QtComboBox
        id: vocationList
        anchors.fill: target
        visible: false
        @onSetup: |
          self:addOption('Knight')
          self:addOption('Paladin')
          self:addOption('Monk')
          self:addOption('Sorcerer')
          self:addOption('Druid')

      UIWidget
        id: targetLabel
        !text: 'Target:'
        color: #C0C0C0
        anchors.left: parent.left
        anchors.verticalCenter: target.verticalCenter
        text-horizontal-auto-resize: true
        margin-left: 5

      QtCheckBox
        id: virtueOfSustain
        anchors.bottom: save.top
        anchors.right: save.right
        text-horizontal-auto-resize: true
        !text: 'Use Virtue'
        image-rect: 70 0 14 14
        text-align: left
        text-offset: 0 -2
        margin-bottom: 5
        margin-right: 15
        color: #C0C0C0

      UIWidget
        id: virtueOfSustainMask
        anchors.fill: virtueOfSustain
        margin-right: -18
        !tooltip: 'Auto use Virtue of Sustain before casting this spell.'
        @onLeftClick: |
          local check = self:getParent():getChildById('virtueOfSustain')
          if check ~= nil and check:isEnabled() then
            check:setChecked(not(check:isChecked()))
          end

  UIWidget
    id: dropDownCatcher
    anchors.fill: parent
    visible: false

  ScrollablePanel
    id: dropDownMenu
    padding-right: 14
    image-source: /resources/border_minibot_dropdown
    image-border: 5
    vertical-scrollbar: dropDownMenuScrollBar
    anchors.left: parent.left
    anchors.top: parent.top
    margin-left: 50
    margin-top: 264
    size: 295 98
    padding: 8
    visible: false
    layout:
      type: grid
      cell-size: 34 34
      cell-spacing: 4
      flow: true

  VerticalScrollBar
    id: dropDownMenuScrollBar
    anchors.top: dropDownMenu.top
    anchors.bottom: dropDownMenu.bottom
    anchors.right: dropDownMenu.right
    margin-top: 2
    margin-right: 2
    margin-bottom: 2
    step: 32
    pixels-scroll: true
    visible: false
